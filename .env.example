# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# ── Docker / nginx server URLs ──────────────────────────────────────────────
# When running via Docker (npm run serve), start-server.sh auto-sets PUBLIC_URL
# to your LAN IP. Override manually if needed:
#
#   PUBLIC_URL=http://192.168.1.100
#   NGINX_PORT=80
#
# CORS: use * to allow any frontend origin (LAN + remote), or comma-separated list:
#   CORS_ORIGINS=http://192.168.1.100:3001,http://localhost:3001
CORS_ORIGINS=*
PUBLIC_URL=http://localhost
NGINX_PORT=80
APP_URL=http://localhost

# ── Local development (without Docker) ──────────────────────────────────────
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/devsinn_insights?schema=public

# Database (used when running NestJS locally; Docker uses internal postgres service)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/devsinn_insights?schema=public

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Email (Nodemailer)
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@devsinn.com

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_SUCCESS_URL=http://localhost:3001/payment/success
STRIPE_CANCEL_URL=http://localhost:3001/payment/cancel

# File Upload
UPLOAD_STORAGE=local
UPLOAD_LOCAL_PATH=./uploads
UPLOAD_MAX_SIZE_MB=5
AWS_S3_BUCKET=
AWS_S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=1000
AUTH_THROTTLE_LIMIT=10
