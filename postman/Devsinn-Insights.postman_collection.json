{
  "info": {
    "name": "Devsinn Insights API",
    "description": "REST API collection for Devsinn Insights guest posting platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"contributor@devsinn.com\",\n  \"password\": \"Contributor123!\"\n}"
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/auth/logout",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Articles",
      "item": [
        {
          "name": "List Articles (Public)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/articles?page=1&limit=20"
          }
        },
        {
          "name": "Get Article by Slug",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/articles/getting-started-with-nestjs"
          }
        },
        {
          "name": "Create Article",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/articles",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"My Guest Post\",\n  \"content\": \"<p>Article content here with at least ten characters.</p>\",\n  \"submit\": true\n}"
            }
          }
        },
        {
          "name": "My Submissions",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/articles/my-submissions"
          }
        },
        {
          "name": "Update Article Status",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/articles/:id/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"APPROVED\",\n  \"categoryId\": \"category-uuid-here\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Packages & Payments",
      "item": [
        {
          "name": "List Packages",
          "request": { "method": "GET", "url": "{{baseUrl}}/packages" }
        },
        {
          "name": "Checkout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/orders/checkout",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"packageId\": \"00000000-0000-0000-0000-000000000001\"\n}"
            }
          }
        },
        {
          "name": "My Orders",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/orders/my-orders"
          }
        }
      ]
    },
    {
      "name": "SEO",
      "item": [
        {
          "name": "Sitemap Data",
          "request": { "method": "GET", "url": "{{baseUrl}}/seo/sitemap-data" }
        },
        {
          "name": "Bulk Generate SEO Pages",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/seo/pages/bulk-generate",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pageTypes\": [\"CATEGORY\", \"TAG\", \"AUTHOR\", \"WRITE_FOR_US\"]\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/dashboard/stats"
          }
        }
      ]
    }
  ]
}
