generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// ENUMS
//////////////////////////////////////////////////////

enum UserRole {
  ADMIN
  USER
}

enum ContentType {
  ARTICLE
  TEXT
  PDF
  IMAGE
  VIDEO
  MIXED
}

enum ContentStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  CHANGES_REQUESTED
  REJECTED
  PUBLISHED
  UNPUBLISHED
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum CommentStatus {
  VISIBLE
  HIDDEN
}

enum MediaType {
  IMAGE
  VIDEO
  PDF
  DOCUMENT
}

enum BlockType {
  PARAGRAPH
  HEADING
  IMAGE
  VIDEO
  CODE
  QUOTE
  LIST
  EMBED
}

enum NotificationType {
  CONTENT_SUBMITTED
  CONTENT_APPROVED
  CONTENT_PUBLISHED
  CONTENT_REJECTED
  CONTENT_CHANGES_REQUESTED
  CONTENT_UNPUBLISHED
  SUBSCRIPTION_ACTIVATED
  SUBSCRIPTION_EXPIRED
  PAYMENT_CONFIRMED
  PAYMENT_FAILED
  COMMENT_RECEIVED
}

enum EmailLogStatus {
  QUEUED
  SENT
  FAILED
}

enum ReviewAction {
  SUBMITTED
  APPROVED
  REJECTED
  CHANGES_REQUESTED
  PUBLISHED
  UNPUBLISHED
  RESUBMITTED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  PUBLISH
  UNPUBLISH
  APPROVE
  REJECT
  BAN
  UNBAN
}

//////////////////////////////////////////////////////
// USER
//////////////////////////////////////////////////////

model User {
  id    String   @id @default(uuid())
  name  String
  email String   @unique
  password String

  role UserRole @default(USER)

  avatarUrl String?

  bio       String?
  website   String?
  linkedin  String?
  twitter   String?

  emailVerifiedAt DateTime?

  isActive  Boolean  @default(true)
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  //////////////////////////////////////////////////////
  // Relations
  //////////////////////////////////////////////////////

  refreshTokens   RefreshToken[]
  subscriptions   Subscription[]
  payments        Payment[]
  content         Content[]
  contentVersions ContentVersion[]
  comments        Comment[]
  likes           Like[]
  reviewEvents    ReviewEvent[]
  notifications   Notification[]
  uploadedMedia   Media[]
  auditLogs       AuditLog[]

  //////////////////////////////////////////////////////
  // Indexes
  //////////////////////////////////////////////////////

  @@index([role])
  @@index([isActive])
  @@index([deletedAt])
  @@index([email])

  @@map("users")
}

//////////////////////////////////////////////////////
// REFRESH TOKENS
//////////////////////////////////////////////////////

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])

  @@map("refresh_tokens")
}

//////////////////////////////////////////////////////
// SUBSCRIPTION PLANS
//////////////////////////////////////////////////////

model SubscriptionPlan {
  id          String  @id @default(uuid())
  name        String
  description String?
  price       Decimal @db.Decimal(10, 2)
  currency    String  @default("USD")
  durationDays Int
  features    Json
  isActive    Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions Subscription[]

  @@index([isActive])

  @@map("subscription_plans")
}

//////////////////////////////////////////////////////
// SUBSCRIPTIONS
//////////////////////////////////////////////////////

model Subscription {
  id     String @id @default(uuid())
  userId String
  planId String

  status    SubscriptionStatus @default(ACTIVE)
  startDate DateTime
  endDate   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Restrict)

  payments Payment[]

  @@index([userId])
  @@index([planId])
  @@index([status])
  @@index([endDate])

  @@map("subscriptions")
}

//////////////////////////////////////////////////////
// PAYMENTS
//////////////////////////////////////////////////////

model Payment {
  id             String @id @default(uuid())
  userId         String
  subscriptionId String?

  amount   Decimal @db.Decimal(10, 2)
  currency String  @default("USD")

  status PaymentStatus @default(PENDING)

  provider              String  @default("stripe")
  providerTransactionId String? @unique
  providerMetadata      Json?

  invoiceUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([subscriptionId])
  @@index([status])
  @@index([provider])
  @@index([providerTransactionId])

  @@map("payments")
}

//////////////////////////////////////////////////////
// CATEGORIES
//////////////////////////////////////////////////////

model Category {
  id   String @id @default(uuid())
  name String
  slug String @unique

  description     String?
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?

  isActive Boolean @default(true)

  parentCategoryId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parentCategory  Category?  @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id], onDelete: SetNull)
  childCategories Category[] @relation("CategoryHierarchy")

  content  Content[]
  seoPages SeoPage[]

  @@index([slug])
  @@index([parentCategoryId])
  @@index([isActive])

  @@map("categories")
}

//////////////////////////////////////////////////////
// CONTENT
//////////////////////////////////////////////////////

model Content {
  id      String @id @default(uuid())
  title   String
  slug    String @unique

  excerpt     String?
  description String? @db.Text

  authorId   String
  categoryId String?

  contentType ContentType  @default(ARTICLE)
  status      ContentStatus @default(DRAFT)

  coverImageId String?

  metaTitle       String?
  metaDescription String?
  metaKeywords    String?

  readingTimeMinutes Int @default(0)
  viewCount          Int @default(0)

  publishedAt DateTime?
  deletedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  //////////////////////////////////////////////////////
  // Relations
  //////////////////////////////////////////////////////

  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category  Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  coverImage Media?   @relation("ContentCoverImage", fields: [coverImageId], references: [id], onDelete: SetNull)

  contentBlocks    ContentBlock[]
  contentVersions  ContentVersion[]
  comments         Comment[]
  likes            Like[]
  reviewEvents     ReviewEvent[]

  //////////////////////////////////////////////////////
  // Indexes
  //////////////////////////////////////////////////////

  @@index([slug])
  @@index([status])
  @@index([authorId])
  @@index([categoryId])
  @@index([contentType])
  @@index([publishedAt])
  @@index([deletedAt])
  @@index([viewCount])

  @@map("content")
}

//////////////////////////////////////////////////////
// CONTENT VERSION
// Created after every post-publish edit.
// Live version is never overwritten.
//////////////////////////////////////////////////////

model ContentVersion {
  id        String @id @default(uuid())
  contentId String
  editorId  String
  version   Int

  title       String
  description String? @db.Text
  snapshot    Json    // full block snapshot at version time

  changeNote String?

  createdAt DateTime @default(now())

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  editor  User    @relation(fields: [editorId], references: [id], onDelete: Cascade)

  @@unique([contentId, version])
  @@index([contentId])
  @@index([editorId])

  @@map("content_versions")
}

//////////////////////////////////////////////////////
// CONTENT BLOCKS
//////////////////////////////////////////////////////

model ContentBlock {
  id        String @id @default(uuid())
  contentId String
  type      BlockType
  position  Int

  textContent String? @db.Text
  mediaId     String?
  metadata    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  media   Media?  @relation(fields: [mediaId], references: [id], onDelete: SetNull)

  @@index([contentId])
  @@index([position])

  @@map("content_blocks")
}

//////////////////////////////////////////////////////
// MEDIA
//////////////////////////////////////////////////////

model Media {
  id           String @id @default(uuid())
  fileName     String
  originalName String
  url          String
  mimeType     String
  mediaType    MediaType
  fileSize     Int

  width  Int?
  height Int?

  altText         String?
  storageProvider String  @default("local")
  storageKey      String?

  uploadedById String

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  uploadedBy User @relation(fields: [uploadedById], references: [id], onDelete: Cascade)

  contentBlocks      ContentBlock[]
  contentCoverImages Content[] @relation("ContentCoverImage")

  @@index([uploadedById])
  @@index([mediaType])
  @@index([deletedAt])

  @@map("media")
}

//////////////////////////////////////////////////////
// COMMENTS
// Only USER, only on PUBLISHED content, immediately visible.
// ADMIN can hide or hard-delete.
// No replies, no editing, no self-delete.
//////////////////////////////////////////////////////

model Comment {
  id        String @id @default(uuid())
  contentId String
  userId    String

  body String @db.Text

  status CommentStatus @default(VISIBLE)

  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@index([userId])
  @@index([status])
  @@index([deletedAt])

  @@map("comments")
}

//////////////////////////////////////////////////////
// LIKES
// One like per user per content. Toggle on second click.
//////////////////////////////////////////////////////

model Like {
  id        String @id @default(uuid())
  contentId String
  userId    String

  createdAt DateTime @default(now())

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([contentId, userId])
  @@index([contentId])
  @@index([userId])

  @@map("likes")
}

//////////////////////////////////////////////////////
// REVIEW EVENTS
// Complete audit trail of every status transition.
//////////////////////////////////////////////////////

model ReviewEvent {
  id        String @id @default(uuid())
  contentId String
  actorId   String

  action     ReviewAction
  fromStatus ContentStatus?
  toStatus   ContentStatus

  note String?

  createdAt DateTime @default(now())

  content Content @relation(fields: [contentId], references: [id], onDelete: Cascade)
  actor   User    @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([contentId])
  @@index([actorId])
  @@index([action])
  @@index([createdAt])

  @@map("review_events")
}

//////////////////////////////////////////////////////
// NOTIFICATIONS
//////////////////////////////////////////////////////

model Notification {
  id     String @id @default(uuid())
  userId String

  type    NotificationType
  title   String
  message String

  metadata Json?

  isRead Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([type])

  @@map("notifications")
}

//////////////////////////////////////////////////////
// EMAIL LOG
//////////////////////////////////////////////////////

model EmailLog {
  id           String @id @default(uuid())
  toEmail      String
  templateName String
  subject      String
  status       EmailLogStatus @default(QUEUED)
  errorMessage String?
  sentAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([toEmail])

  @@map("email_logs")
}

//////////////////////////////////////////////////////
// SEO PAGES
//////////////////////////////////////////////////////

enum SeoPageType {
  CATEGORY
  AUTHOR
  HOME
  CUSTOM
}

model SeoPage {
  id   String @id @default(uuid())
  slug String @unique
  type SeoPageType

  title           String
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  ogImage         String?
  canonicalUrl    String?

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([type])
  @@index([isActive])

  @@map("seo_pages")
}

//////////////////////////////////////////////////////
// AUDIT LOG
//////////////////////////////////////////////////////

model AuditLog {
  id       String @id @default(uuid())
  actorId  String
  action   AuditAction
  entity   String // e.g. "Content", "User", "Comment"
  entityId String
  metadata Json?

  createdAt DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@index([entity])
  @@index([entityId])
  @@index([action])
  @@index([createdAt])

  @@map("audit_logs")
}

//////////////////////////////////////////////////////
// SITE SETTINGS
//////////////////////////////////////////////////////

model SiteSetting {
  id    String @id @default(uuid())
  key   String @unique
  value String @db.Text
  label String?
  group String?
  isPublic Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
  @@index([group])
  @@index([isPublic])

  @@map("site_settings")
}

//////////////////////////////////////////////////////
// CONTACT MESSAGES
//////////////////////////////////////////////////////

model ContactMessage {
  id      String @id @default(uuid())
  name    String
  email   String
  subject String
  message String @db.Text

  isRead Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isRead])
  @@index([email])

  @@map("contact_messages")
}

//////////////////////////////////////////////////////
// NEWSLETTER SUBSCRIBERS
//////////////////////////////////////////////////////

model NewsletterSubscriber {
  id    String @id @default(uuid())
  email String @unique
  name  String?

  isActive       Boolean  @default(true)
  unsubscribeToken String  @unique @default(uuid())

  subscribedAt   DateTime @default(now())
  unsubscribedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
  @@index([email])
  @@index([unsubscribeToken])

  @@map("newsletter_subscribers")
}
