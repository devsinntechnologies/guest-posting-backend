generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  EDITOR
  CONTRIBUTOR
}

enum ArticleStatus {
  DRAFT
  PENDING_REVIEW
  APPROVED
  REJECTED
  PUBLISHED
  ARCHIVED
}

enum CommentStatus {
  PENDING
  APPROVED
  SPAM
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

enum SponsoredPlacement {
  HOMEPAGE
  CATEGORY
  SIDEBAR
}

enum LinkInsertionStatus {
  PENDING
  APPROVED
  REJECTED
  LIVE
}

enum NotificationType {
  SUBMISSION_RECEIVED
  STATUS_CHANGED
  PAYMENT_CONFIRMED
  ARTICLE_PUBLISHED
  ARTICLE_REJECTED
  COMMENT_RECEIVED
  LINK_INSERTION_UPDATE
}

enum EmailLogStatus {
  QUEUED
  SENT
  FAILED
}

enum SeoPageType {
  CATEGORY
  TAG
  AUTHOR
  WRITE_FOR_US
}

model User {
  id              String    @id @default(uuid())
  name            String
  email           String    @unique
  password        String
  role            UserRole  @default(CONTRIBUTOR)
  companyName     String?
  websiteUrl      String?
  avatarUrl       String?
  isActive        Boolean   @default(true)
  emailVerifiedAt DateTime?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  articles         Article[]
  comments         Comment[]
  submissionLogs   SubmissionLog[]
  orders           Order[]
  sponsoredPosts   SponsoredPost[]
  linkInsertions   LinkInsertion[] @relation("LinkInsertionRequester")
  notifications    Notification[]
  refreshTokens    RefreshToken[]

  @@index([role])
  @@index([isActive])
  @@map("users")
}

model Category {
  id               String     @id @default(uuid())
  name             String
  slug             String     @unique
  description      String?
  metaTitle        String?
  metaDescription  String?
  parentCategoryId String?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  parentCategory Category?  @relation("CategoryHierarchy", fields: [parentCategoryId], references: [id], onDelete: SetNull)
  childCategories Category[] @relation("CategoryHierarchy")
  articles        Article[]

  @@index([slug])
  @@index([parentCategoryId])
  @@map("categories")
}

model Tag {
  id        String       @id @default(uuid())
  name      String
  slug      String       @unique
  createdAt DateTime     @default(now())

  articleTags ArticleTag[]

  @@index([slug])
  @@map("tags")
}

model Article {
  id                  String        @id @default(uuid())
  title               String
  slug                String        @unique
  content             String        @db.Text
  excerpt             String?
  featuredImageUrl    String?
  authorId            String
  categoryId          String?
  status              ArticleStatus @default(DRAFT)
  targetUrl           String?
  anchorText          String?
  metaTitle           String?
  metaDescription     String?
  metaKeywords        String?
  readingTimeMinutes  Int           @default(0)
  viewCount           Int           @default(0)
  rejectionReason     String?
  publishedAt         DateTime?
  deletedAt           DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  author         User            @relation(fields: [authorId], references: [id], onDelete: Cascade)
  category       Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  articleTags    ArticleTag[]
  comments       Comment[]
  submissionLogs SubmissionLog[]
  orders         Order[]
  sponsoredPosts SponsoredPost[]
  linkInsertions LinkInsertion[] @relation("LinkInsertionTarget")

  @@index([slug])
  @@index([status])
  @@index([categoryId])
  @@index([authorId])
  @@index([publishedAt])
  @@map("articles")
}

model ArticleTag {
  articleId String
  tagId     String

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@map("article_tags")
}

model Comment {
  id              String        @id @default(uuid())
  articleId       String
  userId          String?
  guestName       String?
  guestEmail      String?
  content         String        @db.Text
  status          CommentStatus @default(PENDING)
  parentCommentId String?
  deletedAt       DateTime?
  createdAt       DateTime      @default(now())

  article       Article   @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user          User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  parentComment Comment?  @relation("CommentReplies", fields: [parentCommentId], references: [id], onDelete: SetNull)
  replies       Comment[] @relation("CommentReplies")

  @@index([articleId])
  @@index([status])
  @@index([userId])
  @@map("comments")
}

model SubmissionLog {
  id         String         @id @default(uuid())
  articleId  String
  actorId    String
  fromStatus ArticleStatus?
  toStatus   ArticleStatus
  note       String?
  createdAt  DateTime       @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  actor   User    @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([actorId])
  @@index([createdAt])
  @@map("submission_logs")
}

model Package {
  id           String   @id @default(uuid())
  name         String
  description  String?
  price        Decimal  @db.Decimal(10, 2)
  currency     String   @default("USD")
  features     Json     @default("[]")
  durationDays Int      @default(30)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders Order[]

  @@map("packages")
}

model Order {
  id                   String      @id @default(uuid())
  userId               String
  packageId            String?
  articleId            String?
  amount               Decimal     @db.Decimal(10, 2)
  currency             String      @default("USD")
  status               OrderStatus @default(PENDING)
  paymentGateway       String      @default("stripe")
  gatewayTransactionId String?     @unique
  invoiceUrl           String?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt

  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  package        Package?        @relation(fields: [packageId], references: [id], onDelete: SetNull)
  article        Article?        @relation(fields: [articleId], references: [id], onDelete: SetNull)
  linkInsertions LinkInsertion[]

  @@index([userId])
  @@index([status])
  @@index([gatewayTransactionId])
  @@map("orders")
}

model SponsoredPost {
  id        String             @id @default(uuid())
  articleId String
  userId    String
  startDate DateTime
  endDate   DateTime
  placement SponsoredPlacement
  isActive  Boolean            @default(true)

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([articleId])
  @@index([isActive])
  @@index([startDate, endDate])
  @@map("sponsored_posts")
}

model LinkInsertion {
  id              String              @id @default(uuid())
  requestedById   String
  targetArticleId String
  anchorText      String
  destinationUrl  String
  status          LinkInsertionStatus @default(PENDING)
  price           Decimal             @db.Decimal(10, 2)
  paymentId       String?
  createdAt       DateTime            @default(now())

  requestedBy   User    @relation("LinkInsertionRequester", fields: [requestedById], references: [id], onDelete: Cascade)
  targetArticle Article @relation("LinkInsertionTarget", fields: [targetArticleId], references: [id], onDelete: Cascade)
  payment       Order?  @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([requestedById])
  @@index([targetArticleId])
  @@index([status])
  @@map("link_insertions")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
  @@map("notifications")
}

model EmailLog {
  id           String         @id @default(uuid())
  toEmail      String
  templateName String
  subject      String
  status       EmailLogStatus @default(QUEUED)
  errorMessage String?
  sentAt       DateTime?
  createdAt    DateTime       @default(now())

  @@index([status])
  @@index([toEmail])
  @@map("email_logs")
}

model SeoPage {
  id              String      @id @default(uuid())
  pageType        SeoPageType
  referenceId     String?
  slug            String      @unique
  metaTitle       String?
  metaDescription String?
  h1Heading       String?
  customContent   String?     @db.Text
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([slug])
  @@index([pageType])
  @@index([referenceId])
  @@map("seo_pages")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}
